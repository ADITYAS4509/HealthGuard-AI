# ============================================================
# ENVIRONMENT VARIABLES — HealthGuard AI
# Copy this file to .env and fill in your actual values.
# ⚠️ NEVER commit your .env file to version control!
# ============================================================

# --- Google Gemini (AI Diagnosis & Translation) ---
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Override the default Gemini model
# GEMINI_MODEL=gemini-2.0-flash

# --- RapidAPI (Tier 1 Medical Diagnosis) ---
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=ai-medical-diagnosis.p.rapidapi.com

# --- Brevo (OTP Email Service) ---
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=your_verified_sender_email@example.com

# --- Flask (Session Security) ---
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_this_to_a_strong_random_secret_key

# --- Optional: Environment Detection ---
# Set to 'production' when deploying to a live server
# APP_ENV=development
